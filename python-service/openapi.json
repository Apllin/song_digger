            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/ytm/search-exact": {
      "get": {
        "summary": "Search Exact",
        "description": "Exact track lookup: search YTM for 'artist - title', pick the best matching\nresult by comparing normalised artist+title strings.\nReturns { embedUrl, coverUrl } or { embedUrl: null }.",
        "operationId": "search_exact_ytm_search_exact_get",
        "parameters": [
          {
            "name": "title",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Title"
            }
          },
          {
            "name": "artist",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "title": "Artist"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "additionalProperties": true,
                  "title": "Response Search Exact Ytm Search Exact Get"
                }
              }
            }
          },
          "422": {
            "description": "Validation Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
