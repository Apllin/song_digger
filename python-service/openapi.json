              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            }
          }
        }
      }
    },
    "/discogs/release/{release_id}/tracklist": {
      "get": {
        "summary": "Get Tracklist",
        "operationId": "get_release_tracklist",
        "parameters": [
          {
            "name": "release_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "title": "Release Id"
            }
          },
          {
            "name": "release_type",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "pattern": "^(release|master)$",
              "default": "release",
              "title": "Release Type"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful Response",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/TracklistItem"
                  },
                  "title": "Response Get Release Tracklist"
                }
