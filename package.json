{
  "name": "track-digger",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "setup": "turbo run setup",
    "codegen": "turbo run codegen",
    "stack:up": "pnpm codegen && docker-compose --env-file ./.env up --build",
    "stack:down": "docker-compose --env-file ./.env down"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.9.6"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma"
    ]
  }
}
