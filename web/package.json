{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "with-env": "dotenv -e ../.env --",
    "dev": "pnpm run with-env next dev",
    "build": "pnpm run with-env next build",
    "start": "pnpm run with-env next start",
    "lint": "pnpm run with-env eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "pnpm run with-env vitest run --config vitest.smoke.config.ts",
    "test:speed": "pnpm run with-env vitest run --config vitest.speed.config.ts",
    "test:all": "pnpm test && pnpm test:smoke && pnpm test:speed"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@types/pg": "^8.20.0",
    "axios": "^1.15.0",
    "cheerio": "^1.2.0",
    "jotai": "^2.19.1",
    "next": "16.2.3",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.1",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
