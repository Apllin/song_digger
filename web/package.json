{
  "name": "@trackdigger/web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm run with-env next build",
    "codegen": "kubb",
    "db:generate": "pnpm run with-env prisma generate",
    "dev": "pnpm run with-env next dev",
    "lint": "pnpm run with-env eslint",
    "lint:fix": "pnpm run with-env eslint --fix",
    "start": "pnpm run with-env next start",
    "test": "vitest run",
    "test:all": "pnpm test && pnpm test:smoke && pnpm test:speed",
    "test:smoke": "pnpm run with-env vitest run --config vitest.smoke.config.ts",
    "test:speed": "pnpm run with-env vitest run --config vitest.speed.config.ts",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../.env --"
  },
  "prettier": "@vanya2h/prettier-config",
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@hono/zod-validator": "^0.7.6",
    "@paper-design/shaders-react": "^0.0.76",
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@react-three/fiber": "^9.6.1",
    "@tanstack/react-query": "^5.100.9",
    "@types/pg": "^8.20.0",
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cal-sans": "^1.0.1",
    "cheerio": "^1.2.0",
    "dotenv": "^17.4.1",
    "dotenv-cli": "^11.0.0",
    "hono": "^4.12.18",
    "jotai": "^2.19.1",
    "mitt": "^3.0.1",
    "next": "16.2.3",
    "next-auth": "5.0.0-beta.31",
    "pg": "^8.20.0",
    "prisma": "^7.7.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "three": "^0.184.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@kubb/cli": "^4.37.5",
    "@kubb/core": "^4.37.5",
    "@kubb/plugin-client": "^4.37.5",
    "@kubb/plugin-oas": "^4.37.5",
    "@kubb/plugin-ts": "^4.37.5",
    "@kubb/plugin-zod": "^4.37.5",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vanya2h/eslint-config": "^0.7.0",
    "@vanya2h/prettier-config": "^0.7.0",
    "@vanya2h/typescript-config": "^0.7.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "prettier": "^3.8.3",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
