generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Track {
  id             String          @id @default(cuid())
  title          String
  artist         String
  source         String
  sourceUrl      String          @unique
  coverUrl       String?
  embedUrl       String?
  createdAt      DateTime        @default(now())
  favorites      Favorite[]
  playlistTracks PlaylistTrack[]
  searchResults  SearchResult[]

  @@index([source])
}

// Auth.js v5 — see ADR-0020. JWT sessions, but Prisma adapter still
// requires Account/Session tables. Account stays empty until OAuth lands.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  favorites      Favorite[]
  dislikedTracks DislikedTrack[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 6-digit email verification codes. Stored bcrypt-hashed so DB
// compromise doesn't leak in-flight codes. 15-minute expiry.
model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// 32-byte hex token mailed as a reset link. 1-hour expiry.
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model SearchQuery {
  id        String         @id @default(cuid())
  input     String
  status    String         @default("pending")
  createdAt DateTime       @default(now())
  results   SearchResult[]
}

model SearchResult {
  id            String      @id @default(cuid())
  searchQueryId String
  trackId       String
  score         Float?
  // All adapter sources that contributed this candidate to THIS search,
  // captured from the aggregator's `appearances` (RRF fusion). Track.source
  // stores only the first/primary source — that loses attribution when
  // multiple sources surface the same identity. The UI renders one chip
  // per entry.
  sources       String[]    @default([])
  searchQuery   SearchQuery @relation(fields: [searchQueryId], references: [id], onDelete: Cascade)
  track         Track       @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([searchQueryId, trackId])
  @@index([searchQueryId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId])
}

model DislikedTrack {
  id        String   @id @default(cuid())
  userId    String
  // Normalized identity keys for matching against candidate tracks.
  // Same normalization as web/lib/aggregator.ts:normalizeArtist /
  // normalizeTitle (NFKD diacritic strip + lowercase + drop
  // non-alphanumerics for artist; whitelisted suffix-strip + lowercase
  // for title).
  artistKey String
  titleKey  String
  // Originals retained for UI display.
  artist    String
  title     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artistKey, titleKey])
  @@index([userId, artistKey])
}

model Playlist {
  id        String          @id @default(cuid())
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tracks    PlaylistTrack[]
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  order      Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId, order])
}

model LastfmArtistSimilars {
  id String @id @default(cuid())

  // Lowercased, trimmed seed artist name. Mirrors the _normalize convention
  // used by the trackid co-occurrence cache in app/core/db.py.
  seedArtist String @unique

  // JSON list of {name, match, url} objects from Last.fm artist.getSimilar.
  // Stored as Json (not relational rows) because reads are always all-at-once
  // for a seed, refreshes are atomic (replace whole row), and Last.fm's
  // response is naturally a list.
  similars Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}
