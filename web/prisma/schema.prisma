generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Track {
  id                String              @id @default(cuid())
  title             String
  artist            String
  source            String
  sourceUrl         String              @unique
  coverUrl          String?
  embedUrl          String?
  createdAt         DateTime            @default(now())
  favorites         Favorite?
  playlistTracks    PlaylistTrack[]
  searchResults     SearchResult[]
  candidateFeatures CandidateFeatures[]

  @@index([source])
}

model SearchQuery {
  id                String              @id @default(cuid())
  input             String
  status            String              @default("pending")
  createdAt         DateTime            @default(now())
  results           SearchResult[]
  candidateFeatures CandidateFeatures[]
}

model SearchResult {
  id            String      @id @default(cuid())
  searchQueryId String
  trackId       String
  score         Float?
  searchQuery   SearchQuery @relation(fields: [searchQueryId], references: [id], onDelete: Cascade)
  track         Track       @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([searchQueryId, trackId])
  @@index([searchQueryId])
}

model Favorite {
  id        String   @id @default(cuid())
  trackId   String   @unique
  createdAt DateTime @default(now())
  track     Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)
}

model DislikedTrack {
  id        String   @id @default(cuid())
  // Normalized identity keys for matching against candidate tracks.
  // Same normalization as web/lib/aggregator.ts:normalizeArtist /
  // normalizeTitle (NFKD diacritic strip + lowercase + drop
  // non-alphanumerics for artist; whitelisted suffix-strip + lowercase
  // for title).
  artistKey String
  titleKey  String
  // Originals retained for UI display.
  artist    String
  title     String
  createdAt DateTime @default(now())

  @@unique([artistKey, titleKey])
  @@index([artistKey])
}

model Playlist {
  id        String          @id @default(cuid())
  name      String
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  tracks    PlaylistTrack[]
}

model PlaylistTrack {
  id         String   @id @default(cuid())
  playlistId String
  trackId    String
  order      Int
  playlist   Playlist @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  track      Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistId, trackId])
  @@index([playlistId, order])
}

model TrackidCooccurrence {
  id            String   @id @default(cuid())

  seedTrackidId String
  pairTrackidId String

  pairArtist    String
  pairTitle     String

  setCount      Int      @default(1)

  pairUrl       String

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([seedTrackidId, pairTrackidId])
  @@index([seedTrackidId])
  @@index([updatedAt])
}

model LastfmArtistSimilars {
  id         String   @id @default(cuid())

  // Lowercased, trimmed seed artist name. Mirrors the _normalize convention
  // used by the trackid co-occurrence cache in app/core/db.py.
  seedArtist String   @unique

  // JSON list of {name, match, url} objects from Last.fm artist.getSimilar.
  // Stored as Json (not relational rows) because reads are always all-at-once
  // for a seed, refreshes are atomic (replace whole row), and Last.fm's
  // response is naturally a list.
  similars   Json

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([updatedAt])
}

model ArtistDiscography {
  id              String   @id @default(cuid())

  // Lowercased artist name with diacritics stripped via NFKD + non-alphanumerics
  // dropped — mirrors web/lib/aggregator.ts:normalizeArtist so the same key
  // resolves whether the lookup originates from the web side (identityKey) or
  // python-service.
  artistName      String   @unique

  // Discogs artist ID. Numeric upstream; stored as String to match the rest of
  // the ID columns in this schema and to keep the column null-safe when the
  // search step found nothing.
  discogsArtistId String?

  // JSON array of releases:
  //   [{ releaseId: string, year: number, title: string, label: string }, ...]
  // Sorted by year ascending. Source for both yearProximity lookups and the
  // collaborator extraction in ArtistCollaborations.
  releases        Json

  // Year of the artist's earliest known release; cheap to derive at write
  // time and useful as a Stage D feature on its own ("how long has this
  // artist been around?") without re-scanning the JSON.
  debutYear       Int?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([updatedAt])
}

model ArtistCollaborations {
  id            String   @id @default(cuid())

  // Same normalization as ArtistDiscography.artistName.
  artistName    String   @unique

  // JSON array of collaborator artist names (normalized).
  // Derived from ArtistDiscography.releases — when artist A appears on a
  // release with artist B, B ends up in A's collaborators set.
  collaborators Json

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([updatedAt])
}

model CandidateFeatures {
  id String @id @default(cuid())

  searchQueryId String
  trackId       String

  // C1 features (cheap, computed at search-persistence time)
  bpmDelta    Float?
  keyCompat   Float?
  energyDelta Float?
  labelMatch  Float?
  genreMatch  Float?
  nSources    Int
  topRank     Int
  hasEmbed    Int
  rrfScore    Float

  // C2 features (Discogs, eventually-consistent — populated by background job)
  yearProximity   Float?
  artistCorelease Int?

  // C3 features (joined from cache tables once trackid lands enabled)
  cooccurrenceTrackid Int?
  appearsInLastfm     Int?
  appearsInCosine     Int?
  appearsInYandex     Int?

  createdAt DateTime @default(now())

  searchQuery SearchQuery @relation(fields: [searchQueryId], references: [id], onDelete: Cascade)
  track       Track       @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([searchQueryId, trackId])
  @@index([searchQueryId])
  @@index([trackId])
  @@index([createdAt])
}
