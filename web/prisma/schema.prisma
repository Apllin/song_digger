generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Track {
  id             String          @id @default(cuid())
  title          String
  artist         String
  source         String
  sourceUrl      String          @unique
  coverUrl       String?
  embedUrl       String?
  createdAt      DateTime        @default(now())
  favorites      Favorite[]
  searchResults  SearchResult[]

  @@index([source])
}

// Auth.js v5 — see ADR-0020. JWT sessions, but Prisma adapter still
// requires Account/Session tables. Account stays empty until OAuth lands.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  passwordHash  String?
  name          String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  favorites      Favorite[]
  dislikedTracks DislikedTrack[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// 6-digit email verification codes. Stored bcrypt-hashed so DB
// compromise doesn't leak in-flight codes. 15-minute expiry.
model VerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

// 32-byte hex token mailed as a reset link. 1-hour expiry.
model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model SearchQuery {
  id        String         @id @default(cuid())
  input     String
  cacheKey  String?
  status    String         @default("pending")
  createdAt DateTime       @default(now())
  results   SearchResult[]

  @@index([cacheKey, status, createdAt])
}

model SearchResult {
  id            String      @id @default(cuid())
  searchQueryId String
  trackId       String
  score         Float?
  // All adapter sources that contributed this candidate to THIS search,
  // captured from the aggregator's `appearances` (RRF fusion). Track.source
  // stores only the first/primary source — that loses attribution when
  // multiple sources surface the same identity. The UI renders one chip
  // per entry.
  sources       String[]    @default([])
  searchQuery   SearchQuery @relation(fields: [searchQueryId], references: [id], onDelete: Cascade)
  track         Track       @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([searchQueryId, trackId])
  @@index([searchQueryId])
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  trackId   String
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  track Track @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId])
}

model DislikedTrack {
  id        String   @id @default(cuid())
  userId    String
  // Normalized identity keys for matching against candidate tracks.
  // Same normalization as web/lib/aggregator.ts:normalizeArtist /
  // normalizeTitle (NFKD diacritic strip + lowercase + drop
  // non-alphanumerics for artist; whitelisted suffix-strip + lowercase
  // for title).
  artistKey String
  titleKey  String
  // Originals retained for UI display.
  artist    String
  title     String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, artistKey, titleKey])
  @@index([userId, artistKey])
}

// Per-IP counter for anonymous (unauthenticated) requests. Pooled across
// /api/search, /api/discography/search, /api/discography/label/search.
// Persistent until the user registers — Stage K may add periodic cleanup.
// See ADR-0021.
model AnonymousRequest {
  id      String   @id @default(cuid())
  ip      String   @unique
  count   Int      @default(0)
  firstAt DateTime @default(now())
  lastAt  DateTime @default(now())
}

// One row per login attempt, kept for as long as the rate-limit and
// backoff windows need it (15 min for IP, 1 hour for email backoff).
// Stage K may add a periodic cleanup job — for now the table grows
// unbounded but stays small in absolute terms. ADR-0021.
model LoginAttempt {
  id        String   @id @default(cuid())
  ip        String
  // null when the submitted email failed Zod parse (still recorded
  // against IP so the per-IP cap protects against random probing).
  email     String?
  success   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
  @@index([email, createdAt])
}

// Embed-URL cache keyed by normalized (artistKey, titleKey). Populated lazily
// by /api/discography/embed (and warmed by search saveTracks). Positive hits
// (embedUrl != null) never expire — YouTube videoIds and Bandcamp track-ids
// are stable. Negative hits (embedUrl == null) expire after 7 days so newly
// uploaded tracks eventually become discoverable. Lazy invalidation on player
// error is in the backlog.
model TrackEmbed {
  id String @id @default(cuid())

  // Same normalization convention as DislikedTrack: aggregator.ts
  // normalizeArtist / normalizeTitle.
  artistKey String
  titleKey  String

  // null = "we looked and didn't find" (negative cache, 7-day TTL via updatedAt).
  embedUrl  String?
  sourceUrl String?
  source    String? // "youtube_music" | "bandcamp" | null
  coverUrl  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([artistKey, titleKey])
  @@index([updatedAt])
}

// Generic cache for external-API responses (Discogs metadata, iTunes covers,
// MusicBrainz suggestions, Trackidnet DJ-set tracklists).
// One row per (source, cacheKey). `payload` is the raw JSON response shape
// that the caller persisted; readers cast it back to a typed shape themselves.
//
// TTL is enforced on the read path by comparing now() - updatedAt against a
// caller-supplied ttlSeconds (None/undefined = never expires). We don't store
// the TTL in the row — it's a property of the read site, so the same cached
// payload can be served with different freshness windows from different
// callers if needed.
model ExternalApiCache {
  id        String   @id @default(cuid())
  source    String
  cacheKey  String
  payload   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([source, cacheKey])
  @@index([source, updatedAt])
}

// Per-request cost telemetry. One row per HTTP request handled by the Hono
// app, plus one row per background task that wraps itself in
// `runWithMetrics(...)` (currently: the fire-and-forget search worker).
//
// Used for cost attribution before launch: which routes burn the most CPU,
// which run the most DB queries, which call into Python and how long that
// took. Read-only analysis target — query with SQL, no UI yet.
//
// `route` for background work is prefixed with `BG ` so it's visually
// distinct from the synchronous request that spawned it (e.g. `BG /api/search`
// is the post-response worker for `POST /api/search`).
model RequestMetric {
  id            String   @id @default(cuid())
  route         String
  method        String
  statusCode    Int
  durationMs    Int
  cpuMs         Int
  responseBytes Int      @default(0)
  // Null for routes that never call Python.
  pythonDurationMs Int?
  // True = served from SearchQuery cache, false = live Python fan-out, null = not a search route.
  cacheHit      Boolean?
  // Adapter source names that returned tracks (search route only).
  sourcesUsed   Json?
  userId        String?
  createdAt     DateTime @default(now())

  @@index([route, createdAt])
  @@index([createdAt])
}

model LastfmArtistSimilars {
  id String @id @default(cuid())

  // Lowercased, trimmed seed artist name. Mirrors the _normalize convention
  // used by the trackid co-occurrence cache in app/core/db.py.
  seedArtist String @unique

  // JSON list of {name, match, url} objects from Last.fm artist.getSimilar.
  // Stored as Json (not relational rows) because reads are always all-at-once
  // for a seed, refreshes are atomic (replace whole row), and Last.fm's
  // response is naturally a list.
  similars Json

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([updatedAt])
}
