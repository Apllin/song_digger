{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build", "codegen"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "dependsOn": ["codegen"],
      "cache": false,
      "persistent": true
    },
    "lint": {},
    "lint:fix": {},
    "test": {},
    "setup": {
      "cache": false
    },
    "codegen": {
      "dependsOn": ["@track-digger/python-service#codegen"],
      "inputs": ["../python-service/openapi.json", "kubb.config.ts"],
      "outputs": ["lib/python-api/generated/**"]
    },
    "@track-digger/python-service#codegen": {
      "inputs": ["app/**/*.py", "scripts/export_openapi.py"],
      "outputs": ["openapi.json"]
    }
  }
}
